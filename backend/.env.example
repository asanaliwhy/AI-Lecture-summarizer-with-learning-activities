PORT=8082
ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lectura?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Generate with: openssl rand -hex 64
JWT_SECRET=

GEMINI_API_KEY=
GEMINI_REQUESTS_PER_MINUTE=30
GEMINI_TOKENS_PER_MINUTE=500000
GEMINI_CONCURRENT_REQUESTS=3

STORAGE_TYPE=local
STORAGE_PATH=./uploads

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lectura.app

FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Also add while here:
CONTENT_READY_TIMEOUT_SECONDS=120

TLS_CERT_PATH=
TLS_KEY_PATH=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lectura
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8082
FRONTEND_PORT=5173
